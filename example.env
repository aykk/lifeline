# Copy to .env.local (never commit .env.local). On Vercel: Settings → Environment Variables
# for Production and Preview. Names must match exactly, including NEXT_PUBLIC_ prefix.

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional (server-only); only if you add server-side admin code
# SUPABASE_SERVICE_ROLE_KEY=

# Bland AI (outbound calls)
# BLAND_AI_API_KEY=

# Google Gemini (AI Mode)
# GEMINI_API_KEY=
